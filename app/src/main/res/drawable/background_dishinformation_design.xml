<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Shadow layer -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#80000000"/> <!-- Shadow color with transparency -->
            <corners android:radius="10dp"/>
            <padding
                android:left="1dp"
                android:right="2dp"
                android:top="1dp"
                android:bottom="2dp"/>
        </shape>
    </item>

    <!-- Content layer -->
    <item android:left="1dp" android:right="4dp" android:top="1dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/transparent2"/>
            <corners android:radius="10dp"/>
        </shape>
    </item>
</layer-list>