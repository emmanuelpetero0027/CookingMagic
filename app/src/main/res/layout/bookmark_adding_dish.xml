<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="View.Bookmark.AddBookmark">


    <AutoCompleteTextView
        android:id="@+id/autoComplete_searchBar_bookmark"
        android:layout_width="250dp"
        android:layout_height="50dp"
        android:layout_marginStart="32dp"
        android:layout_marginTop="32dp"
        android:layout_weight="1"
        android:background="@drawable/icon_custom_searchbar"
        android:drawableStart="@drawable/icon_search"
        android:drawablePadding="12dp"
        android:ems="10"
        android:hint="Search"
        android:imeOptions="actionSearch"
        android:inputType="text"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:queryHint="Search Ingredient"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btn_voiceRecognitionSearch_bookmark"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginStart="8dp"
        android:layout_weight="1"
        android:background="#00FFFFFF"
        android:src="@drawable/icon_voicesearch"
        app:layout_constraintBottom_toBottomOf="@+id/autoComplete_searchBar_bookmark"
        app:layout_constraintStart_toEndOf="@+id/autoComplete_searchBar_bookmark"
        app:layout_constraintTop_toTopOf="@+id/autoComplete_searchBar_bookmark" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_dishInformation_bookmark"
        android:layout_width="match_parent"
        android:layout_height="600dp"
        android:layout_marginTop="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btn_bookmarkResetDish" />

    <Button
        android:id="@+id/btn_bookmarkResetDish"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginTop="16dp"
        android:visibility="invisible"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/autoComplete_searchBar_bookmark" />

</androidx.constraintlayout.widget.ConstraintLayout>