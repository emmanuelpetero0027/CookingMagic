<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="BottomNavigationBar.Bookmark">

    <FrameLayout
        android:id="@+id/frameLayout2"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/imageview"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:scaleType="centerCrop"

            android:src="@drawable/generate_collapsing_header"
            app:layout_collapseMode="parallax" />

        <TextView
            android:id="@+id/textView9"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="Bookmarks"
            android:textColor="@color/white"
            android:textSize="40dp"
            android:fontFamily="@font/yummy"/>

    </FrameLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_bookmarkList"
        android:layout_width="match_parent"
        android:layout_height="500dp"
        android:layout_marginTop="32dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/frameLayout2">

    </androidx.recyclerview.widget.RecyclerView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_addDateBookmark"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="32dp"
        android:clickable="true"
        android:src="@drawable/icon_add"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_calendar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="32dp"
        android:clickable="true"
        android:src="@drawable/icon_calendar"
        app:layout_constraintBottom_toTopOf="@+id/fab_addDateBookmark"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="@+id/fab_calendar"
        app:layout_constraintStart_toEndOf="@+id/fab_calendar"
        app:layout_constraintTop_toTopOf="@+id/fab_calendar" />

    <TextView
        android:id="@+id/tv_addBookmark"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Press + to Bookmark a Dish"
        android:textSize="24dp"
        app:layout_constraintBottom_toBottomOf="@+id/rv_bookmarkList"
        app:layout_constraintEnd_toEndOf="@+id/rv_bookmarkList"
        app:layout_constraintStart_toStartOf="@+id/rv_bookmarkList"
        app:layout_constraintTop_toTopOf="@+id/rv_bookmarkList" />

</androidx.constraintlayout.widget.ConstraintLayout>